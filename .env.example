# ── Gmail SMTP (Email notifications) ──────────────────────────────────────────
# Use a Gmail App Password — NOT your real Gmail password.
# Enable 2FA on your Google account first, then create an App Password at:
#   https://myaccount.google.com/apppasswords
GMAIL_SENDER_EMAIL=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Twilio (SMS notifications) ────────────────────────────────────────────────
# Sign up at https://www.twilio.com and get a phone number.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+91

# ── Supabase (already configured) ─────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-anon-key
